{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atomic",
  "version": "1.12.0",
  "identifier": "com.atomic.app",
  "build": {
    "beforeDevCommand": "npm run build:server && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:server && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atomic",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/atomic-server"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": null
    }
  }
}
