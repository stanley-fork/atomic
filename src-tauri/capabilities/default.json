{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:default",
    "core:window:allow-start-dragging",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text"
  ]
}

